{
  "tests": [
    {
      "name": "login без данных — 400",
      "method": "POST",
      "path": "/",
      "body": {"action": "login", "email": "", "password": ""},
      "expectedStatus": 400,
      "bodyMatcher": "partial",
      "expectedBody": {"error": "Введите email и пароль"}
    },
    {
      "name": "login неверные данные — 401",
      "method": "POST",
      "path": "/",
      "body": {"action": "login", "email": "fake@admin.com", "password": "wrongpass"},
      "expectedStatus": 401,
      "bodyMatcher": "partial",
      "expectedBody": {"error": "Неверный email или пароль"}
    },
    {
      "name": "me без токена — 401",
      "method": "POST",
      "path": "/",
      "body": {"action": "me"},
      "expectedStatus": 401,
      "bodyMatcher": "partial",
      "expectedBody": {"error": "Нет доступа"}
    },
    {
      "name": "stats без токена — 401",
      "method": "POST",
      "path": "/",
      "body": {"action": "stats"},
      "expectedStatus": 401,
      "bodyMatcher": "partial",
      "expectedBody": {"error": "Нет доступа"}
    },
    {
      "name": "quick_links без токена — 401",
      "method": "POST",
      "path": "/",
      "body": {"action": "quick_links"},
      "expectedStatus": 401,
      "bodyMatcher": "partial",
      "expectedBody": {"error": "Нет доступа"}
    },
    {
      "name": "settings_get без токена — 401",
      "method": "POST",
      "path": "/",
      "body": {"action": "settings_get", "group": "general"},
      "expectedStatus": 401,
      "bodyMatcher": "partial",
      "expectedBody": {"error": "Нет доступа"}
    },
    {
      "name": "settings_save без данных — 401",
      "method": "POST",
      "path": "/",
      "body": {"action": "settings_save", "data": {"site_name": "Test"}},
      "expectedStatus": 401,
      "bodyMatcher": "partial",
      "expectedBody": {"error": "Нет доступа"}
    },
    {
      "name": "server_time UTC — 200",
      "method": "POST",
      "path": "/",
      "body": {"action": "server_time", "timezone": "UTC"},
      "expectedStatus": 200,
      "bodyMatcher": "partial",
      "expectedBody": {"timezone": "UTC"}
    },
    {
      "name": "server_time неверный TZ — 400",
      "method": "POST",
      "path": "/",
      "body": {"action": "server_time", "timezone": "Invalid/Zone"},
      "expectedStatus": 400,
      "bodyMatcher": "partial",
      "expectedBody": {"error": "Неверный часовой пояс"}
    },
    {
      "name": "my_ip — 200",
      "method": "POST",
      "path": "/",
      "body": {"action": "my_ip"},
      "expectedStatus": 200,
      "bodyMatcher": "partial",
      "expectedBody": {}
    },
    {
      "name": "settings_save security валидация admin_filename — 422",
      "method": "POST",
      "path": "/",
      "body": {"action": "settings_save", "data": {"admin_filename": ""}},
      "expectedStatus": 401,
      "bodyMatcher": "partial",
      "expectedBody": {"error": "Нет доступа"}
    },
    {
      "name": "settings_save security валидация logs_retention — без токена 401",
      "method": "POST",
      "path": "/",
      "body": {"action": "settings_save", "data": {"admin_logs_retention_days": 10}},
      "expectedStatus": 401,
      "bodyMatcher": "partial",
      "expectedBody": {"error": "Нет доступа"}
    },
    {
      "name": "logs без токена — 401",
      "method": "POST",
      "path": "/",
      "body": {"action": "logs"},
      "expectedStatus": 401,
      "bodyMatcher": "partial",
      "expectedBody": {"error": "Нет доступа"}
    },
    {
      "name": "settings_save admin_path невалидный — 401 без токена",
      "method": "POST",
      "path": "/",
      "body": {"action": "settings_save", "data": {"admin_path": "no-slash"}},
      "expectedStatus": 401,
      "bodyMatcher": "partial",
      "expectedBody": {"error": "Нет доступа"}
    }
  ]
}