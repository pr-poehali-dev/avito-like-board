{
  "tests": [
    {
      "name": "POST status — сайт онлайн",
      "method": "POST",
      "path": "/",
      "body": {"action": "status"},
      "expectedStatus": 200,
      "bodyMatcher": "partial",
      "expectedBody": {"ok": true}
    },
    {
      "name": "POST categories — список категорий",
      "method": "POST",
      "path": "/",
      "body": {"action": "categories"},
      "expectedStatus": 200,
      "bodyMatcher": "partial",
      "expectedBody": {"ok": true}
    },
    {
      "name": "POST list — список объявлений",
      "method": "POST",
      "path": "/",
      "body": {"action": "list"},
      "expectedStatus": 200,
      "bodyMatcher": "partial",
      "expectedBody": {"ok": true}
    },
    {
      "name": "POST category_fields — поля категории (без category_id)",
      "method": "POST",
      "path": "/",
      "body": {"action": "category_fields"},
      "expectedStatus": 400,
      "bodyMatcher": "partial",
      "expectedBody": {"error": "Укажите category_id"}
    },
    {
      "name": "POST category_fields — поля категории (с category_id)",
      "method": "POST",
      "path": "/",
      "body": {"action": "category_fields", "category_id": 1},
      "expectedStatus": 200,
      "bodyMatcher": "partial",
      "expectedBody": {"ok": true}
    },
    {
      "name": "POST create без авторизации — 401",
      "method": "POST",
      "path": "/",
      "body": {"action": "create", "title": "Тест", "price": 1000, "category": "test", "city": "Москва"},
      "expectedStatus": 401,
      "bodyMatcher": "partial",
      "expectedBody": {"error": "Необходима авторизация"}
    },
    {
      "name": "GET view несуществующего — 404",
      "method": "GET",
      "path": "/?action=view&id=999999",
      "expectedStatus": 404,
      "bodyMatcher": "partial",
      "expectedBody": {"error": "Объявление не найдено"}
    }
  ]
}
