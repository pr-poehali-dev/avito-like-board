{
  "tests": [
    {
      "name": "GET / — список объявлений",
      "method": "GET",
      "path": "/",
      "expectedStatus": 200,
      "bodyMatcher": "partial",
      "expectedBody": {"ok": true}
    },
    {
      "name": "POST create без авторизации — 401",
      "method": "POST",
      "path": "/",
      "body": {"action": "create", "title": "Тест", "price": 1000, "category": "electronics", "city": "Москва"},
      "expectedStatus": 401,
      "bodyMatcher": "partial",
      "expectedBody": {"error": "Необходима авторизация"}
    },
    {
      "name": "POST update без авторизации — 401",
      "method": "POST",
      "path": "/",
      "body": {"action": "update", "id": 1, "title": "Тест", "price": 1000, "category": "electronics", "city": "Москва"},
      "expectedStatus": 401,
      "bodyMatcher": "partial",
      "expectedBody": {"error": "Необходима авторизация"}
    },
    {
      "name": "GET view несуществующего — 404",
      "method": "GET",
      "path": "/?action=view&id=999999",
      "expectedStatus": 404,
      "bodyMatcher": "partial",
      "expectedBody": {"error": "Объявление не найдено"}
    },
    {
      "name": "POST categories — 200",
      "method": "POST",
      "path": "/",
      "body": {"action": "categories"},
      "expectedStatus": 200,
      "bodyMatcher": "partial",
      "expectedBody": {"ok": true}
    },
    {
      "name": "POST list — 200",
      "method": "POST",
      "path": "/",
      "body": {"action": "list"},
      "expectedStatus": 200,
      "bodyMatcher": "partial",
      "expectedBody": {"ok": true}
    }
  ]
}